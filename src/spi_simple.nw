== Verifier

Two checks, each parses one firmware summary line from the
captured MP135 UART. The 1-lane check parses the `stream <N> B
1lane in <ms> ms, <Mbps> Mbps, crc32=<...>, expect=<...>,
firsterr=<n>, ...` line, computes wall-rate from the
bench_start/bench_done marks in `timeline.log`, and gates on
firsterr=-1 plus wall_rate >= 100 Mbps. The quad check parses the
`twin <N> B quad raw pass1=<ms> ms pass2=<ms> ms crc32=<...>
firsterr=<n> ...` line, computes pass1_rate from firmware-reported
pass1 ms (less noisy than wall-rate which includes test_serv UART
overhead), and gates on firsterr=-1 plus pass1_rate >= 200 Mbps.
Helpers are copied verbatim from src/spi_quad.nw and
src/spi_1lane_stream.nw -- no new parser logic.

<<verify.py>>=
import os
import re
import sys

sys.path.insert(0, os.path.join(
    os.path.dirname(os.path.abspath(__file__)), "..", "..", "lib"))
import verify_lib as v


UART = "streams/mp135.uart.bin"
TIMELINE = "timeline.log"
QSPI_KER_HZ = 656_000_000

STREAM_RE = re.compile(
    rb"stream\s+(\d+)\s+B\s+(1lane|quad)\s+in\s+"
    rb"(\d+)\s+ms,\s+(\d+\.\d+)\s+Mbps,\s+crc32=([0-9a-f]+),\s+"
    rb"expect=([0-9a-f]+),\s+firsterr=(-?\d+),\s+chunk=(\d+),\s+"
    rb"chunks=(\d+),\s+(?:buf=(sram|ddr|crc),\s+)?auto=(on|off)"
    rb"(?:,\s+presc=(\d+),\s+qspi_hz=(\d+))?")


def _read(path):
    if not os.path.isfile(path):
        sys.stderr.write(f"{path} missing\n")
        return None
    with open(path, "rb" if path == UART else "r",
              encoding=None if path == UART else "utf-8",
              errors=None if path == UART else "replace") as f:
        return f.read()


def _bench_wall_ms():
    text = _read(TIMELINE)
    if text is None:
        return None
    def _t(tag):
        m = re.search(r"^\s*(\d+\.\d+)\s+MARK\s+ctrl\s+" + re.escape(tag) + r"\s*$",
                      text, flags=re.MULTILINE)
        return float(m.group(1)) if m else None
    s, d = _t("bench_start"), _t("bench_done")
    if s is None or d is None:
        return None
    return max(0.0, (d - s) * 1000.0)


def check_1lane_mission():
    if not v.check_no_errors():
        return False
    raw = _read(UART)
    if raw is None:
        return False
    last = None
    for m in STREAM_RE.finditer(raw):
        if int(m.group(1)) == 33554432 and m.group(2) == b"1lane":
            last = m
    if last is None:
        sys.stderr.write("no 1lane stream summary for 33554432 B\n")
        sys.stderr.write(raw[-512:].decode("ascii", "replace") + "\n")
        return False
    firsterr = int(last.group(7))
    crc, exp = last.group(5).decode(), last.group(6).decode()
    eff_mbps = float(last.group(4).decode())
    wall_ms = _bench_wall_ms()
    wall_rate = (33554432 * 8.0) / (wall_ms * 1000.0) if wall_ms else None
    msg = (f"1lane stream presc=5 sshift=1 bytes=33554432 "
           f"effective={eff_mbps:.3f}Mbps "
           f"wall_rate={'%.3f' % wall_rate if wall_rate else '?'}Mbps "
           f"crc32={crc} expect={exp} firsterr={firsterr}")
    sys.stdout.write(msg + "\n")
    if firsterr != -1:
        sys.stderr.write(f"firsterr={firsterr}, expected -1\n")
        return False
    if crc != exp:
        sys.stderr.write(f"crc32 mismatch: {crc} vs expect {exp}\n")
        return False
    if wall_rate is None:
        sys.stderr.write("wall_rate=unknown (missing bench marks)\n")
        return False
    if wall_rate < 100.0:
        sys.stderr.write(f"wall_rate={wall_rate:.3f}Mbps below 100 Mbps floor\n")
        return False
    return True


def check_quad_mission():
    if not v.check_no_errors():
        return False
    raw = _read(UART)
    if raw is None:
        return False
    pat = rb"twin\s+16777216\s+B\s+quad\s+raw[^\n]*firsterr=-?\d+"
    m = re.search(pat, raw)
    if not m:
        sys.stderr.write("no twin summary for 16777216 B\n")
        sys.stderr.write(raw[-512:].decode("ascii", "replace") + "\n")
        return False
    line = m.group(0).decode("ascii", "replace")
    firsterr = int(re.search(r"firsterr=(-?\d+)", line).group(1))
    crc_m = re.search(r"crc32=([0-9a-f]+)", line)
    crc = crc_m.group(1) if crc_m else "?"
    pass1_m = re.search(r"pass1=(\d+)\s+ms", line)
    pass1_ms = int(pass1_m.group(1)) if pass1_m else None
    pass1_rate = ((16777216 * 8.0) / (pass1_ms * 1000.0)
                  if pass1_ms else None)
    msg = (f"quad twin-DDR presc=3 sshift=0 bytes=16777216 "
           f"pass1_rate={'%.3f' % pass1_rate if pass1_rate else '?'}Mbps "
           f"crc32={crc} firsterr={firsterr} full={line}")
    sys.stdout.write(msg + "\n")
    if firsterr != -1:
        sys.stderr.write(f"firsterr={firsterr}, expected -1\n")
        return False
    if pass1_rate is None:
        sys.stderr.write("pass1_rate=unknown (no pass1=<ms> in summary)\n")
        return False
    if pass1_rate < 200.0:
        sys.stderr.write(f"pass1_rate={pass1_rate:.3f}Mbps below 200 Mbps floor\n")
        return False
    return True


DISPATCH = {
    "Check 1-lane mission stream presc=5 sshift=1 wall_rate >= 100 Mbps firsterr=-1":
        check_1lane_mission,
    "Check quad mission twin-DDR presc=3 sshift=0 pass1_rate >= 200 Mbps firsterr=-1":
        check_quad_mission,
}


if __name__ == "__main__":
    sys.exit(v.main(DISPATCH, sys.argv))
@

== Test runner

`build/spi_simple/Makefile` is the entry point invoked from
`cd build/spi_simple && make test`. It re-tangles the plan and
verifier from src/spi_simple.nw, symlinks `spi_1lane.bin` and
`spi_quad.bin` from build/spi/ (so the spi chapter remains the
single source of truth for HDL synthesis), then hands off to the
shared run_md.py driver.

<<Makefile>>=
NW := ../../src/spi_simple.nw
MP135_QSPI_DIR := /home/claude/stm32mp135_test_board/baremetal/qspi/build
MP135_QSPI_SRC := /home/claude/stm32mp135_test_board/baremetal/qspi

.PHONY: all test bitstreams sim bitstream
all: TEST.md verify.py spi_1lane.bin spi_quad.bin flash.tsv main.stm32

Makefile: $(NW)
	tangle Makefile < $<

test: all bitstreams
	python3 -u $$TEST_SERV/run_md.py --fresh --ledger ledger.txt --module spi_simple --log run_md.log

bitstreams: spi_1lane.bin spi_quad.bin

bitstream: bitstreams

sim:

TEST.md: $(NW)
	tangle TEST.md < $<

verify.py: $(NW)
	tangle verify.py < $<

spi_1lane.bin:
	$(MAKE) -C ../.. build/spi/spi_1lane.bin
	ln -sf ../spi/spi_1lane.bin $@

spi_quad.bin:
	$(MAKE) -C ../.. build/spi/spi_quad.bin
	ln -sf ../spi/spi_quad.bin $@

flash.tsv:
	ln -sf $(MP135_QSPI_SRC)/flash.tsv $@

main.stm32:
	ln -sf $(MP135_QSPI_DIR)/main.stm32 $@
@

<<spi_simple.mk>>=
# spi_simple: no new RTL. Bitstreams are spi_1lane.bin and
# spi_quad.bin built under build/spi/. We expose them inside
# build/spi_simple/ via symlinks so the in-build-dir Makefile can
# resolve them relatively.

build/spi_simple/spi_1lane.bin: build/spi/spi_1lane.bin | build/spi_simple
	ln -sf ../spi/spi_1lane.bin $@

build/spi_simple/spi_quad.bin: build/spi/spi_quad.bin | build/spi_simple
	ln -sf ../spi/spi_quad.bin $@

build/spi_simple/flash.tsv: | build/spi_simple
	ln -sf $(MP135_QSPI_SRC)/flash.tsv $@

build/spi_simple/main.stm32: | build/spi_simple
	ln -sf $(MP135_QSPI_DIR)/main.stm32 $@

bitstream: build/spi_simple/spi_1lane.bin build/spi_simple/spi_quad.bin
@

== Summary

This chapter is two test blocks and one verifier. The slave RTL
is reproduced as documentation in `<<spi_simple_slave.v>>` --
70 lines including SB_IO instances -- to demonstrate that a SPI
slave is genuinely a shift register and not the 600+ lines of
spi.nw scaffolding. The mission bitstreams come from src/spi.nw
because those are the binaries the iter-1..79 sweep was measured
against; rebuilding them risks regressing the proven (presc, sshift)
sweet spots. The 1-lane mission floor is 100 Mbps (proven
107 Mbps); the quad mission floor is 200 Mbps (proven 337 Mbps,
single-pass, firsterr=-1, presc=3 sshift=0). 400 Mbps quad is
out of reach in SDR mode on this peripheral; see "Why quad is not
4x single" above.
