bench_mcu:reset_dut  # blobs: @main.stm32 (referenced from flash.tsv)
delay ms=2500
dfu.evb:flash_layout layout=@flash.tsv no_reconnect=true
mp135.evb:uart_open
mp135.evb:uart_expect sentinel="JEDEC ID:" timeout_ms=10000
delay ms=300
mp135.evb:uart_write data="p 5 0\r"
delay ms=100
mp135.evb:uart_write data="q 0 16\r"
mp135.evb:uart_expect sentinel="op=6b read 16 @ 0x00000000" timeout_ms=10000
delay ms=300
mp135.evb:uart_write data="q 16 16\r"
mp135.evb:uart_expect sentinel="op=6b read 16 @ 0x00000010" timeout_ms=10000
delay ms=300
