def check_chunk_debug(presc, dummy, length_bytes, chunk_size):
    """Iter 42 chunk-debug sweep. ALWAYS PASS. Looks for either the
    `chunked <len> B chunk=<chunk> ...firsterr=<n>` summary line or
    the `ERR chunked at idx=<i> addr=<a> (<status>)` line and prints
    a CHUNK_DEBUG diagnostic so the operator can see whether the
    chunked command completed (OK with firsterr) or failed
    (HUNG/timeout) at each presc/dummy combination. Cycle 2 iter 58
    extension: dump any MDMADBG instrumentation lines emitted by
    the firmware so the captured HAL_TIMEOUT site is visible."""
    def _check():
        raw = _read_uart()
        if raw is None:
            print(f"CHUNK_DEBUG: presc={presc} dummy={dummy} "
                  f"len={length_bytes} chunk={chunk_size} "
                  f"result=NO_UART")
            return True
        for mdbg in re.finditer(rb"MDMADBG[^\n]*", raw):
            print(f"  MDMADBG: {mdbg.group(0).decode('ascii', 'replace')}")
        ok_pat = (rb"chunked\s+" + str(length_bytes).encode() +
                  rb"\s+B\s+chunk=" + str(chunk_size).encode() +
                  rb"[^\n]*firsterr=-?\d+[^\n]*")
        m_ok = re.search(ok_pat, raw)
        if m_ok:
            line = m_ok.group(0).decode("ascii", "replace")
            firsterr_m = re.search(r"firsterr=(-?\d+)", line)
            firsterr = firsterr_m.group(1) if firsterr_m else "?"
            mbps_m = re.search(r"([\d]+\.[\d]+)\s+Mbps", line)
            fw_mbps = mbps_m.group(1) if mbps_m else "?"
            print(f"CHUNK_DEBUG: presc={presc} dummy={dummy} "
                  f"len={length_bytes} chunk={chunk_size} "
                  f"result=OK firsterr={firsterr} fw_mbps={fw_mbps}")
            print(f"  full: {line}")
            return True
        err_pat = rb"ERR chunked at idx=\d+ addr=\d+ \(-?\d+\)"
        m_err = re.search(err_pat, raw)
        if m_err:
            line = m_err.group(0).decode("ascii", "replace")
            idx_m = re.search(r"idx=(\d+)", line)
            status_m = re.search(r"\((-?\d+)\)", line)
            idx = idx_m.group(1) if idx_m else "?"
            status = status_m.group(1) if status_m else "?"
            print(f"CHUNK_DEBUG: presc={presc} dummy={dummy} "
                  f"len={length_bytes} chunk={chunk_size} "
                  f"result=ERR idx={idx} status={status}")
            print(f"  full: {line}")
            return True
        # Look for chunked_begin line so we know if firmware even started
        begin_pat = (rb"chunked_begin\s+" + str(length_bytes).encode() +
                     rb"\s+B[^\n]*")
        m_begin = re.search(begin_pat, raw)
        if m_begin:
            begin_line = m_begin.group(0).decode("ascii", "replace")
            print(f"CHUNK_DEBUG: presc={presc} dummy={dummy} "
                  f"len={length_bytes} chunk={chunk_size} "
                  f"result=HUNG (begin seen, no completion or ERR)")
            print(f"  begin: {begin_line}")
        else:
            print(f"CHUNK_DEBUG: presc={presc} dummy={dummy} "
                  f"len={length_bytes} chunk={chunk_size} "
                  f"result=HUNG (no chunked_begin observed)")
            tail = raw[-300:].decode("ascii", "replace")
            print(f"  tail: {tail!r}")
        return True  # diagnostic only
    return _check


