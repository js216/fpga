def check_mission_candidate(expected_presc, expected_sshift):
    """Diagnostic-only candidate sweep helper. Always returns True; only
    prints a MISSION CANDIDATE: line so the operator can tabulate
    presc/sshift vs wall_rate vs firsterr across a sweep."""
    def _check():
        if not v.check_no_errors():
            return False
        raw = _read_uart()
        if raw is None:
            sys.stdout.write(
                f"MISSION CANDIDATE: presc={expected_presc} "
                f"sshift={expected_sshift} wall_rate=unknown "
                f"firsterr=? (no UART)\n")
            return True
        m = re.search(rb"stream\s+\d+\s+B\s+quad[^\n]*firsterr=-?\d+", raw)
        if m:
            line = m.group(0).decode("ascii", "replace")
            wall_ms = _bench_wall_ms()
            length_m = re.search(r"stream\s+(\d+)\s+B", line)
            length = int(length_m.group(1)) if length_m else 0
            if wall_ms and wall_ms > 0:
                wall_rate = (length * 8.0) / (wall_ms * 1000.0)
            else:
                wall_rate = 0.0
            firsterr_m = re.search(r"firsterr=(-?\d+)", line)
            firsterr = firsterr_m.group(1) if firsterr_m else "?"
            sys.stdout.write(
                f"MISSION CANDIDATE: presc={expected_presc} "
                f"sshift={expected_sshift} wall_rate={wall_rate:.3f} "
                f"firsterr={firsterr}\n")
            sys.stdout.write(f"  full: {line}\n")
        else:
            sys.stdout.write(
                f"MISSION CANDIDATE: presc={expected_presc} "
                f"sshift={expected_sshift} wall_rate=unknown "
                f"firsterr=? (no stream summary)\n")
        return True  # diagnostic-only -- always pass
    return _check


def check_bench_candidate(presc, sshift, raw_flag):
    """Iter 20 diagnostic: tabulates the polled bench `b` summary line.
    Always passes; logs CAND_BENCH with wall_rate / firsterr / firmware
    Mbps so the operator can see whether `b` (CPU drains FIFO) yields
    coherent data at high prescaler. raw_flag picks dummy=0 vs dummy=8."""
    def _check():
        raw = _read_uart()
        if raw is None:
            print(f"CAND_BENCH: presc={presc} sshift={sshift} "
                  f"raw={raw_flag} HUNG (no UART)")
            return True
        m = re.search(rb"bench\s+\d+\s+B\s+quad[^\n]*firsterr=-?\d+", raw)
        if m:
            line = m.group(0).decode("ascii", "replace")
            try:
                wall_ms = _bench_wall_ms()
                length_m = re.search(r"bench\s+(\d+)\s+B", line)
                length = int(length_m.group(1)) if length_m else 0
                wall_rate = (length * 8) / (wall_ms * 1000) if wall_ms > 0 else 0.0
            except Exception:
                wall_rate = 0.0
            firsterr_m = re.search(r"firsterr=(-?\d+)", line)
            firsterr = firsterr_m.group(1) if firsterr_m else "?"
            mbps_m = re.search(r"([\d]+\.[\d]+)\s+Mbps", line)
            fw_mbps = mbps_m.group(1) if mbps_m else "?"
            print(f"CAND_BENCH: presc={presc} sshift={sshift} "
                  f"raw={raw_flag} wall_rate={wall_rate:.3f} "
                  f"fw_mbps={fw_mbps} firsterr={firsterr}")
            print(f"  full: {line}")
        else:
            err_m = re.search(rb"ERR\s+bench[^\r\n]*", raw)
            err_txt = err_m.group(0).decode("ascii", "replace") if err_m else "no summary"
            print(f"CAND_BENCH: presc={presc} sshift={sshift} "
                  f"raw={raw_flag} HUNG ({err_txt})")
        return True  # diagnostic only
    return _check


def check_mdma_candidate(presc, sshift, length_bytes):
    """Iter 20 diagnostic: tabulates the MDMA-into-DDR `m` summary line.
    Always passes; logs CAND_MDMA with wall_rate / firsterr / firmware
    Mbps so the operator can see whether the MDMA-into-DDR path (no
    auto-consume) yields coherent data at the requested prescaler."""
    def _check():
        raw = _read_uart()
        if raw is None:
            print(f"CAND_MDMA: presc={presc} sshift={sshift} "
                  f"len={length_bytes} HUNG (no UART)")
            return True
        m = re.search(rb"mdma\s+\d+\s+B\s+quad[^\n]*firsterr=-?\d+", raw)
        if m:
            line = m.group(0).decode("ascii", "replace")
            try:
                wall_ms = _bench_wall_ms()
                length_m = re.search(r"mdma\s+(\d+)\s+B", line)
                length = int(length_m.group(1)) if length_m else 0
                wall_rate = (length * 8) / (wall_ms * 1000) if wall_ms > 0 else 0.0
            except Exception:
                wall_rate = 0.0
            firsterr_m = re.search(r"firsterr=(-?\d+)", line)
            firsterr = firsterr_m.group(1) if firsterr_m else "?"
            mbps_m = re.search(r"([\d]+\.[\d]+)\s+Mbps", line)
            fw_mbps = mbps_m.group(1) if mbps_m else "?"
            print(f"CAND_MDMA: presc={presc} sshift={sshift} "
                  f"len={length_bytes} wall_rate={wall_rate:.3f} "
                  f"fw_mbps={fw_mbps} firsterr={firsterr}")
            print(f"  full: {line}")
        else:
            err_m = re.search(rb"ERR\s+mdma[^\r\n]*", raw)
            err_txt = err_m.group(0).decode("ascii", "replace") if err_m else "no summary"
            print(f"CAND_MDMA: presc={presc} sshift={sshift} "
