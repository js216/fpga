def check_dlyb_candidate_v2(presc, sshift, dlyb_unit):
    """Diagnostic-only sweep helper for the iter 19 DLYB+baseline sweep.
    Always returns True; prints a CAND line so the operator can tabulate
    presc/sshift/dlyb_unit vs wall_rate vs firsterr across the sweep.
    Hang-tolerant: does not gate on test_serv errors and reports HUNG
    when no firsterr line is present in the captured UART. Pass
    dlyb_unit=None for no-DLYB baseline rows."""
    def _check():
        raw = _read_uart()
        if raw is None:
            dlyb_str = f"dlyb={dlyb_unit}" if dlyb_unit is not None else "no_dlyb"
            print(f"CAND: presc={presc} sshift={sshift} {dlyb_str} "
                  f"HUNG (no UART)")
            return True
        m = re.search(rb"stream\s+\d+\s+B\s+quad[^\n]*firsterr=-?\d+", raw)
        if m:
            line = m.group(0).decode()
            try:
                wall_ms = _bench_wall_ms()
                length_m = re.search(r"stream\s+(\d+)\s+B", line)
                length = int(length_m.group(1)) if length_m else 0
                wall_rate = (length * 8) / (wall_ms * 1000) if wall_ms > 0 else 0.0
            except Exception:
                wall_rate = 0.0
            firsterr_m = re.search(r"firsterr=(-?\d+)", line)
            firsterr = firsterr_m.group(1) if firsterr_m else "?"
            dlyb_str = f"dlyb={dlyb_unit}" if dlyb_unit is not None else "no_dlyb"
            print(f"CAND: presc={presc} sshift={sshift} {dlyb_str} "
                  f"wall_rate={wall_rate:.3f} firsterr={firsterr}")
            print(f"  full: {line}")
        else:
            dlyb_str = f"dlyb={dlyb_unit}" if dlyb_unit is not None else "no_dlyb"
            print(f"CAND: presc={presc} sshift={sshift} {dlyb_str} HUNG")
        return True  # always pass -- diagnostic
    return _check


def check_mission_wall_rate(mode, presc, min_mbps, byte_count):
    """Mission-target check that ALWAYS logs the wall rate, then enforces
    the rate floor and CRC. This way the operator sees the wall rate
    even when data integrity fails."""
    if not v.check_no_errors():
        return False
    m = _stream_pick(mode, byte_count, presc)
    wall_ms = _bench_wall_ms()
    wall = _wall_rate_mbps(byte_count, wall_ms)
    if m is not None:
        fe = int(m.group(7))
        crc = m.group(5).decode("ascii")
        expect = m.group(6).decode("ascii")
        effective = float(m.group(4).decode("ascii"))
    else:
        fe = None
        crc = "?"
        expect = "?"
        effective = None
    wall_text = "unknown" if wall is None else f"{wall:.3f}"
    eff_text = "unknown" if effective is None else f"{effective:.3f}"
    sys.stdout.write(
        f"MISSION RATE: wall_rate={wall_text} Mbps "
        f"effective={eff_text} Mbps presc={presc} "
        f"bytes={byte_count} firsterr={fe} "
        f"crc32={crc} expect={expect} wall_ms={wall_ms}\n")
    sys.stderr.write(
        f"MISSION RATE: wall_rate={wall_text} Mbps "
        f"effective={eff_text} Mbps presc={presc} "
        f"bytes={byte_count} firsterr={fe} "
        f"crc32={crc} expect={expect} wall_ms={wall_ms}\n")
    if m is None:
        sys.stderr.write(
            f"no {mode} stream summary line for {byte_count} bytes "
            f"presc={presc}\n")
        return False
    if wall is None:
        sys.stderr.write("wall_rate=unknown -- bench marks missing\n")
        return False
    rate_ok = wall >= min_mbps
    if not rate_ok:
        sys.stderr.write(
            f"wall_rate={wall:.3f} Mbps below mission floor "
            f"{min_mbps:.3f} Mbps\n")
    crc_ok = (fe == -1)
    if not crc_ok:
        sys.stderr.write(
            f"firsterr={fe} (expected -1)\n")
    return rate_ok and crc_ok


def check_len_candidate(presc, sshift, length_bytes, mode="stream",
                        tag="CAND_LEN"):
    """Iter 26+33 LENGTH sweep diagnostic. Always passes; extracts
    firsterr from the captured firmware summary line for the requested
    length so the operator can find the shortest LEN at which
    corruption first appears. Prints HUNG when no firsterr line is
    present.

    `mode` selects which firmware command produced the line:
      - "stream"    -> matches `stream <N> B quad ...`
      - "mdma"      -> matches `mdma <N> B quad ...`
      - "bench"     -> matches `bench <N> B quad @ presc=...`
      - "any"       -> matches stream|mdma|bench
    `tag` is the prefix for the CAND_LEN diagnostic line so different
    paths (auto-stream vs MDMA vs polled bench) can be distinguished
    in the captured output."""
    if mode == "stream":
        head = rb"stream"
    elif mode == "mdma":
        head = rb"mdma"
    elif mode == "bench":
        head = rb"bench"
    else:
        head = rb"(?:stream|mdma|bench)"
    def _check():
        raw = _read_uart()
        if raw is None:
            print(f"{tag}: presc={presc} sshift={sshift} "
                  f"len={length_bytes} mode={mode} HUNG (no UART)")
            return True
        pat = (head + rb"\s+" + str(length_bytes).encode() +
               rb"\s+B\s+quad[^\n]*firsterr=-?\d+")
        m = re.search(pat, raw)
        if m:
            line = m.group(0).decode("ascii", "replace")
            try:
                wall_ms = _bench_wall_ms()
                wall_rate = (length_bytes * 8) / (wall_ms * 1000) \
                    if wall_ms and wall_ms > 0 else 0.0
            except Exception:
                wall_rate = 0.0
            firsterr_m = re.search(r"firsterr=(-?\d+)", line)
            firsterr = firsterr_m.group(1) if firsterr_m else "?"
            mbps_m = re.search(r"([\d]+\.[\d]+)\s+Mbps", line)
            fw_mbps = mbps_m.group(1) if mbps_m else "?"
            print(f"{tag}: presc={presc} sshift={sshift} "
                  f"len={length_bytes} mode={mode} "
                  f"wall_rate={wall_rate:.3f} "
                  f"fw_mbps={fw_mbps} firsterr={firsterr}")
            print(f"  full: {line}")
        else:
            err_m = re.search(rb"ERR\s+\w+[^\n]*", raw)
            err_txt = (err_m.group(0).decode("ascii", "replace")
                       if err_m else "(no firmware summary)")
            print(f"{tag}: presc={presc} sshift={sshift} "
                  f"len={length_bytes} mode={mode} HUNG {err_txt!r}")
        return True  # diagnostic only -- always pass
    return _check


def check_diag_discriminator(label):
    """Iter 27 H1/H2 discriminator. ALWAYS PASS. Reads the captured
    `op=6f read 32 @ 0x00000000` hexdump (or any visible firmware ERR)
    and prints a DISCRIM line tagged with the supplied label so the
    operator can compare master-vs-slave alignment hypotheses (H2 =
    shifted ramp `00 12 34 56 78 9a bc de`; H1 = random corruption)."""
    def _check():
        raw = _read_uart()
        if raw is None:
            print(f"DISCRIM {label}: NO_UART")
            return True
        m = re.search(rb"op=6f read[^\n]*\n([\s\S]*?)(?=\n[a-zA-Z]|\Z)", raw)
        if m:
            hexstr = m.group(1).decode(errors='replace').strip()[:200]
            print(f"DISCRIM {label}: {hexstr!r}")
        elif b"ERR" in raw:
            err_line = re.search(rb"ERR[^\n]*", raw)
            err_txt = err_line.group(0).decode(errors='replace') if err_line else '?'
            print(f"DISCRIM {label}: FIRMWARE ERR: {err_txt}")
        else:
            tail = raw[-300:].decode(errors='replace')
            print(f"DISCRIM {label}: NO_DATA tail: {tail!r}")
        return True  # always pass
    return _check


