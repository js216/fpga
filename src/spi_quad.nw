def check_quad_diag_q32():
    if not v.check_no_errors():
        return False
    header = b"op=6b read 32 @ 0x00000000"
    got = _bytes_after(header)
    if got is None:
        sys.stdout.write("quad q32 raw got: <missing header>\n")
        return True  # diagnostic only
    sys.stdout.write(
        f"quad q32 raw got: {' '.join(f'{b:02x}' for b in got[:32])}\n")
    return True  # always pass -- diagnostic only


def check_quad_q32_hexdump(label):
    """Diagnostic helper -- captures the polled `q 0 32` hexdump for the
    most recent UART capture and prints a HEXDUMP line tagged with the
    operator-supplied label so multiple presc/sshift settings can be
    distinguished in the consolidated log. Always returns True so it does
    not gate downstream blocks (we want all three hexdumps even if one
    looks corrupted)."""
    def _check():
        if not v.check_no_errors():
            return False
        header = b"op=6b read 32 @ 0x00000000"
        got = _bytes_after(header)
        if got is None:
            sys.stdout.write(
                f"HEXDUMP {label}: <missing header>\n")
            return True  # diagnostic only
        hexstr = ' '.join(f'{b:02x}' for b in got[:32])
        sys.stdout.write(f"HEXDUMP {label}: {hexstr}\n")
        return True  # always pass -- diagnostic only
    return _check


def check_quad_diag_a32():
    if not v.check_no_errors():
        return False
    raw = _read_uart()
    if raw is None:
        sys.stdout.write("quad A 32 1 0 result: <no UART capture>\n")
        return True  # diagnostic only
    m = re.search(rb"stream\s+32\s+B\s+quad[^\n]*firsterr=-?\d+", raw)
    if m:
        sys.stdout.write(
            f"quad A 32 1 0 result: {m.group(0).decode('ascii', 'replace')}\n")
    else:
        sys.stdout.write("quad A 32 1 0 result: <no stream summary line>\n")
        sys.stdout.write("--- last 512 bytes of UART ---\n")
        sys.stdout.write(raw[-512:].decode("ascii", "replace"))
        sys.stdout.write("\n")
    return True  # always pass -- diagnostic only


