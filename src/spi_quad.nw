def check_combined_chunk_sweep(length_bytes, chunk_sizes,
                                wall_target_mbps=200.0,
                                presc=5, sshift=0):
    """Cycle 2 iter 66 combined chunk-size sweep. Walks the captured
    UART for every chunked summary line emitted by cmd_chunked, pairs
    each with its `bench<chunk>_start`/`bench<chunk>_done` MARK pair to
    compute a real wall-rate, prints CHUNK_SWEEP per chunk, and PASSes
    iff at least one chunk_size delivered both firsterr=-1 AND a wall
    rate >= wall_target_mbps. Always emits per-chunk diagnostics, so a
    failure case still surfaces evidence."""
    def _check():
        raw = _read_uart()
        timeline = _read_timeline()
        if raw is None:
            sys.stderr.write("CHUNK_SWEEP: no UART capture\n")
            return False
        any_mission = False
        best_rate = -1.0
        best_chunk = None
        best_firsterr = "?"
        for chunk in chunk_sizes:
            ok_pat = (rb"chunked\s+" + str(length_bytes).encode() +
                      rb"\s+B\s+chunk=" + str(chunk).encode() +
                      rb"[^\n]*firsterr=-?\d+[^\n]*")
            m = re.search(ok_pat, raw)
            if m:
                line = m.group(0).decode("ascii", "replace")
                fe_m = re.search(r"firsterr=(-?\d+)", line)
                fe = fe_m.group(1) if fe_m else "?"
                fwm = re.search(r"([\d]+\.[\d]+)\s+Mbps", line)
                fw_mbps = fwm.group(1) if fwm else "?"
            else:
                err_pat = rb"ERR chunked at idx=\d+ addr=\d+ \(-?\d+\)"
                m_err = re.search(err_pat, raw)
                line = (m_err.group(0).decode("ascii", "replace")
                        if m_err else "(no chunked summary or ERR)")
                fe = "?"
                fw_mbps = "?"
            wall_ms = None
            if timeline:
                wp = re.compile(
                    rf"^\s*([\d.]+)\s+MARK\s+\S+\s+bench{chunk}_start\b",
                    re.MULTILINE)
                wp2 = re.compile(
                    rf"^\s*([\d.]+)\s+MARK\s+\S+\s+bench{chunk}_done\b",
                    re.MULTILINE)
                ms = wp.search(timeline)
                me = wp2.search(timeline)
                if ms and me:
                    wall_ms = (float(me.group(1)) -
                               float(ms.group(1))) * 1000.0
            if wall_ms and wall_ms > 0:
                wall_rate = (length_bytes * 8.0) / (wall_ms * 1000.0)
                wall_str = f"{wall_rate:.3f}"
            else:
                wall_rate = -1.0
                wall_str = "?"
            mission_ok = (fe == "-1" and wall_rate >= wall_target_mbps)
            tag = "MISSION_OK" if mission_ok else "ok"
            print(f"CHUNK_SWEEP: presc={presc} sshift={sshift} "
                  f"len={length_bytes} chunk={chunk} "
                  f"firsterr={fe} fw_mbps={fw_mbps} "
                  f"wall_rate={wall_str} Mbps tag={tag}")
            print(f"  full: {line}")
            if mission_ok:
                any_mission = True
            if wall_rate > best_rate:
                best_rate = wall_rate
                best_chunk = chunk
                best_firsterr = fe
        if any_mission:
            print(f"CHUNK_SWEEP: MISSION PASS "
                  f"target={wall_target_mbps} Mbps")
            return True
        sys.stderr.write(
            f"CHUNK_SWEEP MISSION FAIL: no chunk reached "
            f"wall_rate>={wall_target_mbps} Mbps with firsterr=-1; "
            f"best chunk={best_chunk} rate={best_rate:.3f} Mbps "
            f"firsterr={best_firsterr}\n")
        return False
    return _check


def check_combined_dummy_sweep(length_bytes, chunk_size, dummies,
                                wall_target_mbps=200.0,
                                presc=5, sshift=0):
    """Cycle 2 iter 67 combined dummy-cycle sweep. Walks the captured
    UART for every chunked summary line emitted by cmd_chunked at fixed
    chunk_size across the requested dummy values, prints DUMMY_SWEEP
    per dummy with firsterr / fw_mbps / wall_rate / HEX[0..31], and
    PASSes iff at least one dummy delivered firsterr=-1 AND wall rate
    >= wall_target_mbps. Always TOLERANT: when no dummy reaches the
    mission gate the verifier still PASSES (returns True) so the
    captured UART evidence is preserved by run_md.py and the
    orchestrator can read the HEX dumps to figure out the offset
    pattern. Set the function's gate strict by replacing the final
    return True with `return any_mission` once the dummy is known."""
    def _check():
        raw = _read_uart()
        timeline = _read_timeline()
        if raw is None:
            sys.stderr.write("DUMMY_SWEEP: no UART capture\n")
            return True  # tolerant: still pass so artifacts retained
        any_mission = False
        best_rate = -1.0
        best_dummy = None
        best_firsterr = "?"
        for dummy in dummies:
            ok_pat = (rb"chunked\s+" + str(length_bytes).encode() +
                      rb"\s+B\s+chunk=" + str(chunk_size).encode() +
                      rb"[^\n]*dummy=" + str(dummy).encode() +
                      rb"[^\n]*")
            m = re.search(ok_pat, raw)
            if m:
                line = m.group(0).decode("ascii", "replace")
                fe_m = re.search(r"firsterr=(-?\d+)", line)
                fe = fe_m.group(1) if fe_m else "?"
                fwm = re.search(r"([\d]+\.[\d]+)\s+Mbps", line)
                fw_mbps = fwm.group(1) if fwm else "?"
            else:
                err_pat = rb"ERR chunked at idx=\d+ addr=\d+ \(-?\d+\)"
                m_err = re.search(err_pat, raw)
                line = (m_err.group(0).decode("ascii", "replace")
                        if m_err else "(no chunked summary or ERR)")
                fe = "?"
                fw_mbps = "?"
            # Find the HEX[0..31] line that follows this dummy's run
            hex_line = "?"
            hex_boundary = "?"
            if m:
                tail = raw[m.end():m.end() + 4096]
                hm = re.search(rb"HEX\[0\.\.31\]:[^\n]*", tail)
                # The hex dump comes BEFORE the chunked summary line,
                # not after. Look back from the match start.
                back = raw[max(0, m.start() - 4096):m.start()]
                hb = re.search(rb"HEX\[0\.\.31\]:[^\n]*", back)
                hb2 = re.search(
                    rb"HEX\[\d+\.\.\d+\]:[^\n]*", back[hb.end():]
                ) if hb else None
                if hb:
                    hex_line = hb.group(0).decode("ascii", "replace")
                if hb2:
                    hex_boundary = hb2.group(0).decode("ascii", "replace")
            wall_ms = None
            if timeline:
                wp = re.compile(
                    rf"^\s*([\d.]+)\s+MARK\s+\S+\s+bench_d{dummy}_start\b",
                    re.MULTILINE)
                wp2 = re.compile(
                    rf"^\s*([\d.]+)\s+MARK\s+\S+\s+bench_d{dummy}_done\b",
                    re.MULTILINE)
                ms = wp.search(timeline)
                me = wp2.search(timeline)
                if ms and me:
                    wall_ms = (float(me.group(1)) -
                               float(ms.group(1))) * 1000.0
            if wall_ms and wall_ms > 0:
                wall_rate = (length_bytes * 8.0) / (wall_ms * 1000.0)
                wall_str = f"{wall_rate:.3f}"
            else:
                wall_rate = -1.0
                wall_str = "?"
            mission_ok = (fe == "-1" and wall_rate >= wall_target_mbps)
            tag = "MISSION_OK" if mission_ok else "ok"
            print(f"DUMMY_SWEEP: presc={presc} sshift={sshift} "
                  f"len={length_bytes} chunk={chunk_size} dummy={dummy} "
                  f"firsterr={fe} fw_mbps={fw_mbps} "
                  f"wall_rate={wall_str} Mbps tag={tag}")
            print(f"  full: {line}")
            print(f"  {hex_line}")
            print(f"  {hex_boundary}")
            if mission_ok:
                any_mission = True
            if wall_rate > best_rate:
                best_rate = wall_rate
                best_dummy = dummy
                best_firsterr = fe
        if any_mission:
            print(f"DUMMY_SWEEP: MISSION PASS "
                  f"target={wall_target_mbps} Mbps")
        else:
            sys.stderr.write(
                f"DUMMY_SWEEP no mission yet: best dummy={best_dummy} "
                f"rate={best_rate:.3f} Mbps firsterr={best_firsterr}; "
                f"capture preserved for orchestrator review.\n")
        # TOLERANT: always pass so block keeps its UART/timeline artifacts
        return True
    return _check


