        ok_pat = (rb"mdma\s+" + str(length_bytes).encode() +
                  rb"\s+B\s+quad[^\n]*firsterr=-?\d+[^\n]*")
        m_ok = re.search(ok_pat, raw)
        wall_ms = _bench_wall_ms()
        wall = _wall_rate_mbps(length_bytes, wall_ms)
        wall_str = "unknown" if wall is None else f"{wall:.3f}"
        wall_ms_str = "unknown" if wall_ms is None else f"{wall_ms:.0f}"
        if m_ok is None:
            err_pat = rb"ERR\s+mdma[^\r\n]*"
            err_m = re.search(err_pat, raw)
            err_txt = (err_m.group(0).decode("ascii", "replace")
                       if err_m else "no summary")
            msg = (f"MISSION_MDMA: presc={presc} len={length_bytes} "
                   f"result=HUNG wall_rate={wall_str} Mbps "
                   f"wall_ms={wall_ms_str} ({err_txt})\n")
            sys.stdout.write(msg)
            sys.stderr.write(msg)
            return False
        line = m_ok.group(0).decode("ascii", "replace")
        firsterr_m = re.search(r"firsterr=(-?\d+)", line)
        firsterr = firsterr_m.group(1) if firsterr_m else "?"
        mbps_m = re.search(r"([\d]+\.[\d]+)\s+Mbps", line)
        fw_mbps = mbps_m.group(1) if mbps_m else "?"
        msg = (f"MISSION_MDMA: presc={presc} len={length_bytes} "
               f"firsterr={firsterr} fw_mbps={fw_mbps} "
               f"wall_rate={wall_str} Mbps wall_ms={wall_ms_str} "
               f"min_mbps={min_mbps:.3f}\n")
        sys.stdout.write(msg)
        sys.stdout.write(f"  full: {line}\n")
        sys.stderr.write(msg)
        if firsterr != "-1":
            sys.stderr.write(
                f"MISSION_MDMA presc={presc}: firsterr={firsterr} "
                f"(need -1)\n")
            return False
        if wall is None:
            sys.stderr.write(
                f"MISSION_MDMA presc={presc}: wall_rate=unknown "
                f"(bench_start/bench_done marks missing)\n")
            return False
        if wall < min_mbps:
            sys.stderr.write(
                f"MISSION_MDMA presc={presc}: wall_rate={wall:.3f} Mbps "
                f"below mission floor {min_mbps:.3f} Mbps\n")
            return False
        return True
    return _check


def check_mdma_diag(presc, length_bytes):
    """Cycle 2 iter 52 diagnostic. Always passes; just surfaces the
    `firsterr_dump @<offset>: ...` line that cmd_mdma now prints right
    before its summary, plus the summary firsterr/Mbps so we can see
    the exact byte pattern around byte 76 without gating on it."""
    def _check():
        raw = _read_uart()
        if raw is None:
            sys.stdout.write(
                f"MDMA_DIAG: presc={presc} len={length_bytes} "
                f"result=NO_UART\n")
            return True
        dump_pat = rb"firsterr_dump\s+@\d+:[^\r\n]*"
        d_m = re.search(dump_pat, raw)
        if d_m is None:
            sys.stdout.write(
                f"MDMA_DIAG: presc={presc} len={length_bytes} "
                f"result=NO_DUMP (firsterr likely -1, or summary missing)\n")
        else:
            dump_line = d_m.group(0).decode("ascii", "replace")
            sys.stdout.write(
                f"MDMA_DIAG: presc={presc} len={length_bytes} "
                f"dump={dump_line}\n")
        sum_pat = (rb"mdma\s+" + str(length_bytes).encode() +
                   rb"\s+B\s+quad[^\n]*firsterr=-?\d+[^\n]*")
        s_m = re.search(sum_pat, raw)
        if s_m is not None:
            sum_line = s_m.group(0).decode("ascii", "replace")
            sys.stdout.write(f"  summary: {sum_line}\n")
        else:
            err_pat = rb"ERR\s+mdma[^\r\n]*"
            err_m = re.search(err_pat, raw)
            if err_m is not None:
                sys.stdout.write(
                    f"  err: {err_m.group(0).decode('ascii', 'replace')}\n")
        return True
    return _check


def check_chunked_summary(presc, sshift, length_bytes, chunk_size):
    """Cycle 2 iter 56 chunked-MDMA diagnostic. ALWAYS PASS. Reads the
    captured UART for either the `chunked <len> B chunk=<chunk> ...
    firsterr=<n>` summary line or the `ERR chunked at idx=<i> addr=<a>
    (<status>)` failure line. Computes wall_rate from the
    bench_start/bench_done MARKs and prints CHUNK_SUMMARY so the
    operator can see firsterr, firmware Mbps, wall rate, and any
    timeout point even on a hung outcome."""
    def _check():
        raw = _read_uart()
        wall_ms = _bench_wall_ms()
        if wall_ms and wall_ms > 0:
            wall_rate = (length_bytes * 8.0) / (wall_ms * 1000.0)
            wall_str = f"{wall_rate:.3f}"
        else:
            wall_str = "?"
        wall_ms_str = "?" if not wall_ms else f"{wall_ms:.0f}"
        if raw is None:
            print(f"CHUNK_SUMMARY: presc={presc} sshift={sshift} "
                  f"len={length_bytes} chunk={chunk_size} "
                  f"result=NO_UART wall_rate={wall_str} Mbps "
                  f"wall_ms={wall_ms_str}")
            return True
        ok_pat = (rb"chunked\s+" + str(length_bytes).encode() +
                  rb"\s+B\s+chunk=" + str(chunk_size).encode() +
                  rb"[^\n]*firsterr=-?\d+[^\n]*")
        m_ok = re.search(ok_pat, raw)
        if m_ok:
            line = m_ok.group(0).decode("ascii", "replace")
            firsterr_m = re.search(r"firsterr=(-?\d+)", line)
            firsterr = firsterr_m.group(1) if firsterr_m else "?"
            mbps_m = re.search(r"([\d]+\.[\d]+)\s+Mbps", line)
            fw_mbps = mbps_m.group(1) if mbps_m else "?"
            print(f"CHUNK_SUMMARY: presc={presc} sshift={sshift} "
                  f"len={length_bytes} chunk={chunk_size} "
                  f"result=OK firsterr={firsterr} fw_mbps={fw_mbps} "
                  f"wall_rate={wall_str} Mbps wall_ms={wall_ms_str}")
            print(f"  full: {line}")
            return True
        err_pat = rb"ERR chunked at idx=\d+ addr=\d+ \(-?\d+\)"
        m_err = re.search(err_pat, raw)
        if m_err:
            line = m_err.group(0).decode("ascii", "replace")
            idx_m = re.search(r"idx=(\d+)", line)
            status_m = re.search(r"\((-?\d+)\)", line)
            idx = idx_m.group(1) if idx_m else "?"
            status = status_m.group(1) if status_m else "?"
            print(f"CHUNK_SUMMARY: presc={presc} sshift={sshift} "
                  f"len={length_bytes} chunk={chunk_size} "
                  f"result=ERR idx={idx} status={status} "
                  f"wall_rate={wall_str} Mbps wall_ms={wall_ms_str}")
            print(f"  full: {line}")
            return True
        # Look for chunked_begin and surrounding context.
        begin_pat = (rb"chunked_begin\s+" + str(length_bytes).encode() +
                     rb"\s+B[^\n]*")
        m_begin = re.search(begin_pat, raw)
        if m_begin:
            print(f"CHUNK_SUMMARY: presc={presc} sshift={sshift} "
                  f"len={length_bytes} chunk={chunk_size} "
                  f"result=HUNG (begin seen, no completion or ERR) "
                  f"wall_rate={wall_str} Mbps wall_ms={wall_ms_str}")
            print(f"  begin: {m_begin.group(0).decode('ascii', 'replace')}")
        else:
            print(f"CHUNK_SUMMARY: presc={presc} sshift={sshift} "
                  f"len={length_bytes} chunk={chunk_size} "
                  f"result=HUNG (no chunked_begin observed) "
                  f"wall_rate={wall_str} Mbps wall_ms={wall_ms_str}")
            tail = raw[-300:].decode("ascii", "replace")
            print(f"  tail: {tail!r}")
        return True  # always pass -- diagnostic only
    return _check


