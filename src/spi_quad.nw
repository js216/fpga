    """Iter 45 STRICT mission target. Parses the
    `mdma <LEN> B quad ... firsterr=<n>` summary line, checks
    firsterr=-1 AND wall_rate (from bench_start/bench_done MARKs)
    >= min_mbps. Always logs MISSION_MDMA so wall rate and firsterr
    are visible whether the block passes or fails."""
    def _check():
        if not v.check_no_errors():
            return False
        raw = _read_uart()
        if raw is None:
            sys.stderr.write(
                f"MISSION_MDMA: presc={presc} len={length_bytes} "
                f"result=NO_UART\n")
