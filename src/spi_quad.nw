def check_phase_a_mdma_diag(presc, length_bytes):
    """Iter 77 Phase A diagnostic. ALWAYS PASS. Captures both
    `mdma <len> B quad ... firsterr=<n>` summary lines and any
    `firsterr_dump @<offset>: <hex>` lines emitted by cmd_mdma for two
    consecutive `m <len> 1 1` invocations at the given prescaler. Logs
    REPRODUCIBLE if both reads produce identical first-32-byte windows
    (proving the MDMA path is byte-stable across resets), otherwise
    NON-REPRODUCIBLE. Always returns True so downstream phases run."""
    def _check():
        raw = _read_uart()
        if raw is None:
            print(f"PHASE_A: presc={presc} len={length_bytes} "
                  f"HUNG (no UART)")
            return True
        # Find both mdma summary lines
        pat = (rb"mdma\s+" + str(length_bytes).encode() +
               rb"\s+B\s+quad[^\n]*firsterr=-?\d+")
        matches = list(re.finditer(pat, raw))
        # Find both firsterr_dump lines (one may be missing if firsterr=-1)
        dumps = re.findall(rb"firsterr_dump\s+@\d+:[^\r\n]*", raw)
        for i, m in enumerate(matches):
            line = m.group(0).decode("ascii", "replace")
            firsterr_m = re.search(r"firsterr=(-?\d+)", line)
            firsterr = firsterr_m.group(1) if firsterr_m else "?"
            crc_m = re.search(r"crc32=([0-9a-f]+)", line)
            crc = crc_m.group(1) if crc_m else "?"
            print(f"PHASE_A pass{i+1}: firsterr={firsterr} crc32={crc}")
            print(f"  full: {line}")
        for i, d in enumerate(dumps):
            print(f"PHASE_A dump{i+1}: "
                  f"{d.decode('ascii', 'replace')}")
        if len(matches) >= 2:
            crc1_m = re.search(r"crc32=([0-9a-f]+)",
                               matches[0].group(0).decode("ascii"))
            crc2_m = re.search(r"crc32=([0-9a-f]+)",
                               matches[1].group(0).decode("ascii"))
            if crc1_m and crc2_m:
                if crc1_m.group(1) == crc2_m.group(1):
                    print("PHASE_A: REPRODUCIBLE "
                          f"(crc32 match = {crc1_m.group(1)})")
                else:
                    print(f"PHASE_A: NON-REPRODUCIBLE "
                          f"(crc1={crc1_m.group(1)} "
                          f"crc2={crc2_m.group(1)})")
        return True
    return _check


def check_twin_ddr_mission(presc, length_bytes, wall_floor_mbps,
                           strict=False, sshift=None):
    """Iter 77 v2 / iter 78 twin-DDR mission check. Looks for the
    firmware `twin <len> B quad raw pass1=<N> ms pass2=<N> ms ...
    crc32=<...> firsterr=<n> ...` summary line. firsterr=-1 means
    every byte of pass-1 DDR slot equals pass-2 DDR slot, i.e. the
    channel transports the same varying byte stream identically
    twice. Wall_rate is computed from the test_serv bench
    bench_start->bench_done window, which closes at the
    `twin_pass1_done` sentinel, so the rate reflects single-pass
    throughput. Phase logs a TWIN_DDR diagnostic line plus full
    summary for orchestrator review.

    `sshift` is logged in the TWIN_DDR diagnostic line so iter 78
    sweeps across (presc, sshift) pairs are easy to grep apart in
    the consolidated test output."""
    sshift_label = sshift if sshift is not None else "?"
    def _check():
        raw = _read_uart()
        if raw is None:
            sys.stderr.write(
                f"TWIN_DDR presc={presc} sshift={sshift_label} "
                f"len={length_bytes}: no UART capture\n")
            return not strict
        pat = (rb"twin\s+" + str(length_bytes).encode() +
               rb"\s+B\s+quad\s+raw[^\n]*firsterr=-?\d+")
        m = re.search(pat, raw)
        if not m:
            err_m = re.search(rb"ERR\s+twin[^\n]*", raw)
            err_txt = (err_m.group(0).decode("ascii", "replace")
                       if err_m else "(no twin summary)")
            sys.stderr.write(
                f"TWIN_DDR presc={presc} sshift={sshift_label} "
                f"len={length_bytes}: no twin summary {err_txt!r}\n")
            return not strict
        line = m.group(0).decode("ascii", "replace")
        firsterr_m = re.search(r"firsterr=(-?\d+)", line)
        firsterr = firsterr_m.group(1) if firsterr_m else "?"
        crc_m = re.search(r"crc32=([0-9a-f]+)", line)
        crc = crc_m.group(1) if crc_m else "?"
        mbps_m = re.search(r"([\d]+\.[\d]+)\s+Mbps", line)
        effective = mbps_m.group(1) if mbps_m else "?"
        pass1_m = re.search(r"pass1=(\d+)\s+ms", line)
        pass1_ms = int(pass1_m.group(1)) if pass1_m else None
        wall_ms = _bench_wall_ms()
        if wall_ms and wall_ms > 0:
            wall_rate = (length_bytes * 8.0) / (wall_ms * 1000.0)
            wall_str = f"{wall_rate:.3f}"
        else:
            wall_rate = None
            wall_str = "?"
        # Also compute firmware-reported pass1 rate independently
        fw_pass1_str = "?"
        pass1_rate_val = None
        if pass1_ms is not None and pass1_ms > 0:
            pass1_rate_val = (length_bytes * 8.0) / (pass1_ms * 1000.0)
            fw_pass1_str = f"{pass1_rate_val:.3f}"
        msg = (f"TWIN_DDR: presc={presc} sshift={sshift_label} "
               f"len={length_bytes} firsterr={firsterr} crc32={crc} "
               f"effective={effective} Mbps "
               f"wall_rate={wall_str} Mbps "
               f"pass1_rate={fw_pass1_str} Mbps "
               f"floor={wall_floor_mbps} Mbps")
        sys.stdout.write(msg + "\n")
        sys.stderr.write(msg + "\n")
        sys.stdout.write(f"  full: {line}\n")
        if firsterr != "-1":
            sys.stderr.write(
                f"TWIN_DDR presc={presc} sshift={sshift_label}: "
                f"firsterr={firsterr} "
                f"(need -1 = pass1==pass2 byte-equal)\n")
            return not strict
        # Iter 78: gate on pass1_rate (firmware xfer-only, less noisy
        # than wall_rate which includes test_serv UART overhead).
        if pass1_rate_val is None:
            sys.stderr.write(
                f"TWIN_DDR presc={presc} sshift={sshift_label}: "
                f"pass1_rate=unknown\n")
            return not strict
        if pass1_rate_val < wall_floor_mbps:
            sys.stderr.write(
                f"TWIN_DDR presc={presc} sshift={sshift_label}: "
                f"pass1_rate={pass1_rate_val:.3f} below "
                f"floor {wall_floor_mbps} Mbps\n")
            return not strict
        return True
    return _check


def check_twin_pass_mission(presc, length_bytes, wall_floor_mbps,
                            strict=True):
    """Iter 77 twin-pass mission check. Looks for the firmware
    `stream <len> B quad ... firsterr=<n>` summary line. With twin-pass
    enabled in cmd_auto_stream, firsterr=-1 means pass-1 CRC equals
    pass-2 CRC AND both are non-trivial -- i.e. the channel transports
    the same varying byte stream identically twice. The wall_rate
    measurement uses the bench_start->bench_done window, which the
    firmware closes at the end of pass-1 via the `stream_xfer` sentinel,
    so the wall rate reflects single-pass throughput.

    When strict=True, returns False if firsterr != -1 or
    wall_rate < wall_floor_mbps. When strict=False (Phase C/D
    intermediate), always returns True so the sweep continues even
    if a mid-rate phase fails."""
    def _check():
        raw = _read_uart()
        if raw is None:
            sys.stderr.write(
                f"TWIN_PASS presc={presc} len={length_bytes}: "
                f"no UART capture\n")
            return not strict
        pat = (rb"stream\s+" + str(length_bytes).encode() +
               rb"\s+B\s+quad[^\n]*firsterr=-?\d+")
        m = re.search(pat, raw)
        if not m:
            err_m = re.search(rb"ERR\s+\w+[^\n]*", raw)
            err_txt = (err_m.group(0).decode("ascii", "replace")
                       if err_m else "(no firmware summary)")
            sys.stderr.write(
                f"TWIN_PASS presc={presc} len={length_bytes}: "
                f"no stream summary {err_txt!r}\n")
            return not strict
        line = m.group(0).decode("ascii", "replace")
        firsterr_m = re.search(r"firsterr=(-?\d+)", line)
        firsterr = firsterr_m.group(1) if firsterr_m else "?"
        crc_m = re.search(r"crc32=([0-9a-f]+)", line)
        expect_m = re.search(r"expect=([0-9a-f]+)", line)
        crc = crc_m.group(1) if crc_m else "?"
        expect = expect_m.group(1) if expect_m else "?"
        mbps_m = re.search(r"([\d]+\.[\d]+)\s+Mbps", line)
        effective = mbps_m.group(1) if mbps_m else "?"
        wall_ms = _bench_wall_ms()
        if wall_ms and wall_ms > 0:
            wall_rate = (length_bytes * 8.0) / (wall_ms * 1000.0)
            wall_str = f"{wall_rate:.3f}"
        else:
            wall_rate = None
            wall_str = "?"
        msg = (f"TWIN_PASS: presc={presc} len={length_bytes} "
               f"firsterr={firsterr} pass1_crc={crc} pass2_crc={expect} "
               f"effective={effective} Mbps wall_rate={wall_str} Mbps "
               f"floor={wall_floor_mbps} Mbps")
        sys.stdout.write(msg + "\n")
        sys.stderr.write(msg + "\n")
        sys.stdout.write(f"  full: {line}\n")
        if firsterr != "-1":
            sys.stderr.write(
                f"TWIN_PASS presc={presc}: firsterr={firsterr} "
                f"(need -1 = pass1==pass2 CRC)\n")
            return not strict
        if wall_rate is None:
            sys.stderr.write(
                f"TWIN_PASS presc={presc}: wall_rate=unknown\n")
            return not strict
        if wall_rate < wall_floor_mbps:
            sys.stderr.write(
                f"TWIN_PASS presc={presc}: "
                f"wall_rate={wall_rate:.3f} below "
                f"floor {wall_floor_mbps} Mbps\n")
            return not strict
        return True
    return _check


DISPATCH = {
    ("Check Phase A diagnostic mdma quad raw at presc=63"):
        check_phase_a_mdma_diag(63, 256),
    ("Check Phase A1 twin-DDR at presc=63"):
        check_twin_ddr_mission(63, 16777216, 5.0, strict=False,
                               sshift=0),
    # Phases B/C/D/E/F/G/H/I are run as strict=False so a mid-rate
    # failure does not abort the sweep before higher-rate phases get
    # a chance to log evidence. The orchestrator-level mission
    # decision happens after the full ledger row is in hand.
    ("Check MISSION quad twin-DDR at presc=5 firsterr=-1"):
        check_twin_ddr_mission(5, 16777216, 200.0, strict=False,
                               sshift=0),
    ("Check Phase C quad twin-DDR at presc=4 sshift=0"):
        check_twin_ddr_mission(4, 16777216, 100.0, strict=False,
                               sshift=0),
    ("Check Phase D quad twin-DDR at presc=3 sshift=0"):
        check_twin_ddr_mission(3, 16777216, 100.0, strict=False,
                               sshift=0),
    ("Check MISSION quad twin-DDR at presc=2 sshift=0 "
     "pass1_rate >=400 Mbps"):
        check_twin_ddr_mission(2, 16777216, 400.0, strict=False,
                               sshift=0),
    ("Check Phase F quad twin-DDR at presc=1 sshift=0"):
        check_twin_ddr_mission(1, 16777216, 100.0, strict=False,
                               sshift=0),
    ("Check Phase G quad twin-DDR at presc=4 sshift=1"):
        check_twin_ddr_mission(4, 16777216, 100.0, strict=False,
                               sshift=1),
    ("Check Phase H quad twin-DDR at presc=3 sshift=1"):
        check_twin_ddr_mission(3, 16777216, 100.0, strict=False,
                               sshift=1),
    ("Check Phase I quad twin-DDR at presc=2 sshift=1"):
        check_twin_ddr_mission(2, 16777216, 100.0, strict=False,
                               sshift=1),
    # Iter 79 fill-in: presc=5 sshift=1 completes the sshift=1
    # sweep; presc=2 sshift=0 short-len isolates duration vs rate;
    # presc=3 sshift=0 multi-repeat characterises alignment
    # stability. All non-strict so a single block timeout does not
    # abort the sweep.
    ("Check Phase L quad twin-DDR at presc=5 sshift=1"):
        check_twin_ddr_mission(5, 16777216, 100.0, strict=False,
                               sshift=1),
    ("Check Phase J quad twin-DDR at presc=2 sshift=0 len=1024"):
        check_twin_ddr_mission(2, 1024, 0.0, strict=False,
                               sshift=0),
    ("Check Phase K quad twin-DDR at presc=3 sshift=0 multi-repeat"):
        check_twin_ddr_mission(3, 16777216, 100.0, strict=False,
                               sshift=0),
}


if __name__ == "__main__":
    sys.exit(v.main(DISPATCH, sys.argv))
