=== Synthesized netlist check

The RTL benches catch the protocol-level "all pull-up" symptom if
the behavioural `SB_IO` model is in the sim path, but they do not
prove that the synthesized netlist still contains the IOB drivers
that make that model relevant. The netlist checker closes that gap
without trying to model board timing: after yosys, each variant must
have exactly four explicit `SB_IO` pads, each pad must be tied to
the matching `io[n]` port bit, each pad must use the direct-output
configuration, and every output enable must be driven by the named
`oe = ~cs_n` net. This is the structural condition the hardware
failure violated when the lanes floated to the master pull-ups and
the MP135 read `0xff`.

<<check_spi_netlist.py>>=
#!/usr/bin/env python3
import json
import sys


def bits_of(module, netname):
    try:
        bits = module["netnames"][netname]["bits"]
    except KeyError:
        raise AssertionError(f"missing net {netname!r}")
    if len(bits) != 1:
        raise AssertionError(f"net {netname!r} is {len(bits)} bits, expected 1")
    return bits[0]


def check(path, lanes):
    with open(path) as f:
        design = json.load(f)
    try:
        module = design["modules"]["spi"]
    except KeyError:
        raise AssertionError(f"{path}: missing top module 'spi'")

    ports = module["ports"]
    io_bits = ports["io"]["bits"]
    oe_bit = bits_of(module, "oe")

    cells = module["cells"]
    bad_tristates = [
        name for name, cell in cells.items()
        if "TBUF" in cell["type"].upper() or "TRIBUF" in cell["type"].upper()
    ]
    if bad_tristates:
        raise AssertionError(f"{path}: inferred fabric tristates remain: {bad_tristates}")

    pads = {
        tuple(cell["connections"].get("PACKAGE_PIN", [])): (name, cell)
        for name, cell in cells.items()
        if cell["type"] == "SB_IO"
    }
    if len(pads) != 4:
        raise AssertionError(f"{path}: found {len(pads)} SB_IO cells, expected 4")

    for lane, io_bit in enumerate(io_bits):
        key = (io_bit,)
        if key not in pads:
            raise AssertionError(f"{path}: missing SB_IO on io[{lane}]")
        name, cell = pads[key]
        params = cell.get("parameters", {})
        conns = cell.get("connections", {})
        expected_pin_type = "101001" if lanes == 4 else "100101"
        if params.get("PIN_TYPE") != expected_pin_type:
            raise AssertionError(
                f"{path}: {name} PIN_TYPE={params.get('PIN_TYPE')}, "
                f"expected {expected_pin_type}")
        if params.get("NEG_TRIGGER") != "1":
            raise AssertionError(f"{path}: {name} NEG_TRIGGER={params.get('NEG_TRIGGER')}, expected 1")
        if conns.get("OUTPUT_ENABLE") != [oe_bit]:
            raise AssertionError(f"{path}: {name} OUTPUT_ENABLE is not oe")
        if "OUTPUT_CLK" not in conns:
            raise AssertionError(f"{path}: {name} missing OUTPUT_CLK")
        dout = conns.get("D_OUT_0", [])
        if lanes == 1:
            should_drive_pattern = lane in (0, 1)
        else:
            should_drive_pattern = True
        if should_drive_pattern and (not dout or isinstance(dout[0], str)):
            raise AssertionError(f"{path}: {name} data input is constant on active lane {lane}")

    print(f"PASS {path}: {lanes}-lane netlist has explicit SB_IO drivers on all pads")


def main(argv):
    if len(argv) < 2:
        raise SystemExit("usage: check_spi_netlist.py json:lanes [json:lanes ...]")
    for spec in argv[1:]:
        path, lanes_s = spec.rsplit(":", 1)
        check(path, int(lanes_s))


if __name__ == "__main__":
    main(sys.argv)
@

=== Build fragment

Two synthesis runs over `verilog/spi.v`, each overriding the
`LANES` macro on the yosys command line. yosys treats `SB_IO`
as an iCE40 primitive so no extra cell library needs to be
read. The two simulator builds add the local `SB_IO` model
(`verilog/SB_IO.v`) to the verilator command alongside
the testbench and the DUT source. The `sim` aggregate also runs
the synthesized-netlist structural check because the pull-up
failure is fundamentally an output-driver presence problem.

