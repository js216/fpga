import os
import re
import sys
import zlib

sys.path.insert(0, os.path.join(
    os.path.dirname(os.path.abspath(__file__)), "..", "..", "lib"))
import verify_lib as v


UART = "streams/mp135.uart.bin"
FPGA_UART = "streams/fpga.uart.bin"
TIMELINE = "timeline.log"
QSPI_KER_HZ = 656_000_000

BENCH_RE = re.compile(
    rb"bench\s+(\d+)\s+B\s+(1lane|quad)\s+@\s+presc=(\d+)\s+in\s+"
    rb"(\d+)\s+ms,\s+(\d+\.\d+)\s+Mbps,\s+crc32=([0-9a-f]+),\s+"
    rb"(?:expect=([0-9a-f]+),\s+)?"
    rb"firsterr=(-?\d+)")
MDMA_RE = re.compile(
    rb"mdma\s+(\d+)\s+B\s+(1lane|quad)\s+in\s+"
    rb"(\d+)\s+ms,\s+(\d+\.\d+)\s+Mbps,\s+crc32=([0-9a-f]+),\s+"
    rb"(?:expect=([0-9a-f]+),\s+)?"
    rb"firsterr=(-?\d+)"
    rb"(?:,\s+xfer=(\d+)\s+ms,\s+validate=(\d+)\s+ms,\s+"
    rb"poison=(\d+)\s+ms)?")
STREAM_RE = re.compile(
    rb"stream\s+(\d+)\s+B\s+(1lane|quad)\s+in\s+"
    rb"(\d+)\s+ms,\s+(\d+\.\d+)\s+Mbps,\s+crc32=([0-9a-f]+),\s+"
    rb"expect=([0-9a-f]+),\s+firsterr=(-?\d+),\s+chunk=(\d+),\s+"
    rb"chunks=(\d+),\s+(?:buf=(sram|ddr|crc),\s+)?auto=(on|off)"
    rb"(?:,\s+presc=(\d+),\s+qspi_hz=(\d+))?")
XOR128_RE = re.compile(
    rb"xor128\s+len=(\d+)\s+iters=(\d+)\s+xor=([0-9a-f]+)\s+"
    rb"cached=(\d+)\s+ms\s+cached_us_x1000=(\d+)\s+"
    rb"cold=(\d+)\s+ms\s+cold_us_x1000=(\d+)")
DEBUG_RE = re.compile(rb"SPI E=([0-9a-f]{4}) S=([0-9a-f]{8})")
Q6B0_RE = re.compile(
    rb"q60 pn=([0-9a-f]{8}) io=([0-9a-f]{8})")
Q6B1_RE = re.compile(
    rb"q61 pn=([0-9a-f]{8}) io=([0-9a-f]{8})")
Q6B_RE = re.compile(rb"q6b pn=([0-9a-f]{8}) io=([0-9a-f]{8})")
Q6B_EXPECT = 0x0708090a
HEXLINE_RE = re.compile(rb"[0-9a-f]{8}:(?:\s+[0-9a-f]{2}){1,16}")
HEXBYTE_RE = re.compile(rb"\b([0-9a-f]{2})\b")

CHECK_RE = re.compile(r"Check\s+(1lane|quad)\s+@\s+presc=(\d+)\s+"
                      r"pattern correct")


def _read_uart():
    if not os.path.isfile(UART):
        sys.stderr.write(f"{UART} missing\n")
        return None
    with open(UART, "rb") as f:
        return f.read()


def _read_fpga_uart():
    if not os.path.isfile(FPGA_UART):
        sys.stderr.write(f"{FPGA_UART} missing\n")
        return None
    with open(FPGA_UART, "rb") as f:
        return f.read()


def _read_timeline():
    if not os.path.isfile(TIMELINE):
        sys.stderr.write(f"{TIMELINE} missing\n")
        return None
    with open(TIMELINE, "r", encoding="utf-8", errors="replace") as f:
        return f.read()


GPIO_READ_RE = re.compile(
    rb"gpio read:\s+CLK=(\d)\s+NCS=(\d)\s+IO0=(\d)\s+IO1=(\d)\s+"
    rb"IO2=(\d)\s+IO3=(\d)")


def _parse_gpio_reads(raw):
    out = []
    for m in GPIO_READ_RE.finditer(raw):
        bits = [int(x) for x in m.groups()]
        mask = 0
        for i, bit in enumerate(bits):
            mask |= (bit & 1) << i
        out.append(mask)
    return out


def _last_debug_line():
    raw = _read_fpga_uart()
    if raw is None:
        return None
    last = None
    for m in DEBUG_RE.finditer(raw):
        last = (int(m.group(1), 16), int(m.group(2), 16))
    if last is None:
        sys.stderr.write("no FPGA debug line matching SPI E=xxxx S=xxxxxxxx\n")
        sys.stderr.write("--- FPGA UART tail ---\n")
        sys.stderr.write(raw[-1024:].decode("ascii", "replace"))
        sys.stderr.write("\n")
    return last


def _last_q6b():
    raw = _read_fpga_uart()
    if raw is None:
        return None
    last = None
    for m in Q6B_RE.finditer(raw):
        last = (int(m.group(1), 16), int(m.group(2), 16))
    if last is None:
        sys.stderr.write("no FPGA q6b line matching q6b pn=xxxxxxxx io=xxxxxxxx\n")
        sys.stderr.write("--- FPGA UART tail ---\n")
        sys.stderr.write(raw[-1024:].decode("ascii", "replace"))
        sys.stderr.write("\n")
    return last


def _last_q6b_if_present():
    raw = _read_fpga_uart()
    if raw is None:
        return None
    last = None
    for m in Q6B_RE.finditer(raw):
        last = (int(m.group(1), 16), int(m.group(2), 16))
    return last


def _last_q6b0():
    raw = _read_fpga_uart()
    if raw is None:
        return None
    last0 = None
    last1 = None
    for m in Q6B0_RE.finditer(raw):
        last0 = (int(m.group(1), 16), int(m.group(2), 16))
    for m in Q6B1_RE.finditer(raw):
        last1 = (int(m.group(1), 16), int(m.group(2), 16))
    if last0 is None:
        return None
    return last0, last1


def _write_q6b0_if_present(stream):
    q6b0 = _last_q6b0()
    if q6b0 is not None:
        stream.write(f"q60 pn={q6b0[0][0]:08x} io={q6b0[0][1]:08x}\n")
        if q6b0[1] is not None:
            stream.write(f"q61 pn={q6b0[1][0]:08x} io={q6b0[1][1]:08x}\n")


def check_gpio_wiring():
    if not v.check_no_errors():
        return False
    raw = _read_uart()
    if raw is None:
        return False
    reads = _parse_gpio_reads(raw)
    expect = [0x00, 0x01, 0x02, 0x04, 0x08, 0x10, 0x20]
    if reads[-len(expect):] != expect:
        sys.stderr.write(
            "GPIO preflight readback mismatch; expected trailing masks "
            + " ".join(f"0x{x:02x}" for x in expect) + "\n")
        sys.stderr.write("--- observed GPIO read masks ---\n")
        sys.stderr.write(" ".join(f"0x{x:02x}" for x in reads[-16:]))
        sys.stderr.write("\n--- MP135 UART tail ---\n")
        sys.stderr.write(raw[-2048:].decode("ascii", "replace"))
        sys.stderr.write("\n")
        return False
    return True


def _bytes_after(header):
    raw = _read_uart()
    if raw is None:
        return None
    pos = raw.find(header)
    if pos < 0:
        sys.stderr.write(f"missing header {header!r}\n")
        sys.stderr.write("--- last 1024 bytes of UART ---\n")
        sys.stderr.write(raw[-1024:].decode("ascii", "replace"))
        sys.stderr.write("\n")
        return None
    out = []
    for line in raw[pos + len(header):].splitlines():
        if not HEXLINE_RE.match(line):
            if out:
                break
            continue
        payload = line.split(b":", 1)[1]
        for m in HEXBYTE_RE.finditer(payload):
            out.append(int(m.group(1), 16))
    return out


def _line_after(header, prefix):
    raw = _read_uart()
    if raw is None:
        return None
    pos = raw.find(header)
    if pos < 0:
        return None
    for line in raw[pos + len(header):].splitlines():
        if line.startswith(prefix):
            return line.decode("ascii", "replace")
    return None


def check_bitbang_pattern(mode):
    if not v.check_no_errors():
        return False
    if mode == "quad":
        header = b"bb 6b read 16 @ 0x00000000"
    else:
        header = b"bb read 16 (1lane io=1)"
    got = _bytes_after(header)
    if got is None:
        if mode == "quad":
            _write_q6b0_if_present(sys.stderr)
            q6b = _last_q6b()
            if q6b is not None:
                sys.stderr.write(f"q6b pn={q6b[0]:08x} io={q6b[1]:08x}\n")
        return False
    expect = list(range(16))
    sys.stdout.write(
        f"{mode} bit-bang got: {' '.join(f'{b:02x}' for b in got[:16])}\n")
    if got[:16] != expect:
        sys.stderr.write(
            f"{mode} bit-bang pattern mismatch; expected "
            f"{' '.join(f'{b:02x}' for b in expect)}\n")
        if mode == "quad":
            line = _line_after(header, b"bb 6b nibbles:")
            if line is not None:
                sys.stderr.write(f"{line}\n")
            _write_q6b0_if_present(sys.stderr)
            q6b = _last_q6b()
            if q6b is not None:
                sys.stderr.write(f"q6b pn={q6b[0]:08x} io={q6b[1]:08x}\n")
        return False
    return True


def check_quad_bitbang_pad_drive():
    if not v.check_no_errors():
        return False
    header = b"bb 6b read 16 @ 0x00000000"
    got = _bytes_after(header)
    if got is None:
        return False
    expect = list(range(16))
    sys.stdout.write(
        "quad bit-bang MP135 bytes: "
        + " ".join(f"{b:02x}" for b in got[:16]) + "\n")
    if got[:16] != expect:
        sys.stderr.write(
            "quad bit-bang MP135 byte mismatch; expected "
            + " ".join(f"{b:02x}" for b in expect)
            + "; validating nibble diagnostic\n")
    line = _line_after(header, b"bb 6b nibbles:")
    if line is not None:
        sys.stdout.write(f"{line}\n")
    else:
        sys.stderr.write("missing MP135 bb 6b nibbles diagnostic\n")
        return False
    got_nibbles = []
    for m in re.finditer(r"\b[0-9a-f]{1,8}\b", line.split(":", 1)[1]):
        token = m.group(0)
        if len(token) == 8:
            packed = int(token, 16)
            got_nibbles.extend(
                (packed >> shift) & 0xff for shift in (24, 16, 8, 0))
        elif len(token) <= 2:
            got_nibbles.append(int(token, 16))
        else:
            sys.stderr.write(f"unexpected MP135 bb 6b nibble token {token}\n")
            return False
    expect_nibbles = [
        0x0, 0x0, 0x1, 0x0, 0x2, 0x0, 0x3, 0x0,
        0x4, 0x0, 0x5, 0x0, 0x6, 0x0, 0x7, 0x0,
        0x8, 0x0, 0x9, 0x0, 0xa, 0x0, 0xb, 0x0,
        0xc, 0x0, 0xd, 0x0, 0xe, 0x0, 0xf, 0x0,
    ]
    if got_nibbles != expect_nibbles:
        sys.stderr.write(
            "MP135 bb 6b nibble mismatch; expected "
            + " ".join(f"{x:02x}" for x in expect_nibbles)
            + ", got "
            + " ".join(f"{x:02x}" for x in got_nibbles) + "\n")
        return False
    return True


def check_raw_read_pattern(mode, count):
    if not v.check_no_errors():
        return False
    if mode == "quad":
        header = f"op=6b read {count} @ 0x00000000".encode("ascii")
    else:
        header = f"raw read {count} (1lane)".encode("ascii")
    got = _bytes_after(header)
    if got is None:
        return False
    expect = [i & 0xff for i in range(count)]
    sys.stdout.write(
        f"{mode} raw got: {' '.join(f'{b:02x}' for b in got[:count])}\n")
    if len(got) < count:
        sys.stderr.write(
            f"{mode} raw short capture: got {len(got)} bytes, "
            f"expected {count}\n")
        return False
    if got[:count] != expect:
        for i, (g, e) in enumerate(zip(got[:count], expect)):
            if g != e:
                sys.stderr.write(
                    f"{mode} raw mismatch at {i}: got {g:02x}, "
                    f"expected {e:02x}\n")
                break
        if mode == "quad":
            _write_q6b0_if_present(sys.stderr)
            q6b = _last_q6b()
            if q6b is not None:
                sys.stderr.write(f"q6b pn={q6b[0]:08x} io={q6b[1]:08x}\n")
        return False
    return True


