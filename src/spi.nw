def _bench_pick(mode, presc):
    raw = _read_uart()
    if raw is None:
        return None
    last = None
    for m in BENCH_RE.finditer(raw):
        if m.group(2).decode() == mode and int(m.group(3)) == presc:
            last = m
    return last


def _mdma_pick(mode, byte_count=1000000):
    raw = _read_uart()
    if raw is None:
        return None
    last = None
    for m in MDMA_RE.finditer(raw):
        if int(m.group(1)) == byte_count and m.group(2).decode() == mode:
            last = m
    return last


def _stream_pick(mode, byte_count=1048576, presc=None):
    raw = _read_uart()
    if raw is None:
        return None
    last = None
    for m in STREAM_RE.finditer(raw):
        if int(m.group(1)) == byte_count and m.group(2).decode() == mode:
            if presc is None:
                last = m
                continue
            if m.group(12) is None:
                continue
            if int(m.group(12)) == presc:
                last = m
    return last


def _sclk_mhz(presc):
    return QSPI_KER_HZ / (presc + 1) / 1_000_000


def _mark_time(text, tag):
    m = re.search(r"^\s*(\d+\.\d+)\s+MARK\s+ctrl\s+" + re.escape(tag) + r"\s*$",
                  text, flags=re.MULTILINE)
    return float(m.group(1)) if m else None


def _bench_wall_ms():
    text = _read_timeline()
    if text is None:
        return None
    start = _mark_time(text, "bench_start")
    done = _mark_time(text, "bench_done")
    if start is None or done is None:
        return None
    return max(0.0, (done - start) * 1000.0)


def _wall_rate_mbps(byte_count, wall_ms):
    if wall_ms is None or wall_ms <= 0.0:
        return None
    return byte_count * 8.0 / (wall_ms * 1000.0)


STREAM_EFFECTIVE_RATE_FLOOR = 0.90
STREAM_WALL_RATE_FLOOR = 0.90


def _physical_max_mbps(mode, presc, qspi_hz=QSPI_KER_HZ):
    lanes = 4 if mode == "quad" else 1
    return (qspi_hz / (presc + 1) / 1_000_000) * lanes


def _rate_bounds_mbps(mode, presc):
    max_rate = _physical_max_mbps(mode, presc)
    return 0.90 * max_rate, max_rate


def _check_rate_bounds(label, mode, presc, rate, qspi_hz=QSPI_KER_HZ):
    max_rate = _physical_max_mbps(mode, presc, qspi_hz)
    lo, hi = 0.90 * max_rate, max_rate
    if rate < lo or rate > hi:
        sys.stderr.write(
            f"{label}={rate:.3f}Mbps outside "
            f"{lo:.3f}..{hi:.3f}Mbps for {mode} presc={presc}\n")
        return False
    return True


def _check_physical_ceiling(label, mode, presc, rate, qspi_hz):
    max_rate = _physical_max_mbps(mode, presc, qspi_hz)
    tolerance = max(0.001, max_rate * 0.001)
    if rate > max_rate + tolerance:
        sys.stderr.write(
            f"{label}={rate:.3f}Mbps above physical ceiling "
            f"{max_rate:.3f}Mbps for {mode} presc={presc}\n")
        return False
    return True


def _check_physical_floor(label, mode, presc, rate, qspi_hz, floor):
    max_rate = _physical_max_mbps(mode, presc, qspi_hz)
    lo = floor * max_rate
    tolerance = max(0.05, max_rate * 0.005)
    if rate < lo - tolerance:
        sys.stderr.write(
            f"{label}={rate:.3f}Mbps below sanity floor "
            f"{lo:.3f}Mbps ({floor:.0%} of physical, "
            f"tolerance {tolerance:.3f}Mbps, "
            f"{max_rate:.3f}Mbps) for {mode} presc={presc}\n")
        return False
    return True


def _wall_text(byte_count, wall_ms):
    if wall_ms is None:
        return " wall=unknown wall_rate=unknown"
    rate = _wall_rate_mbps(byte_count, wall_ms)
    if rate is None:
        return f" wall={wall_ms:.0f}ms wall_rate=unknown"
    return f" wall={wall_ms:.0f}ms wall_rate={rate:.3f}Mbps"


def _bench_rate_text(mode, presc, match):
    byte_count = int(match.group(1))
    ms = int(match.group(4))
    mbps = match.group(5).decode("ascii")
    crc = match.group(6).decode("ascii")
    expect = match.group(7).decode("ascii") if match.group(7) else "unknown"
    wall_ms = _bench_wall_ms()
    wall = _wall_text(byte_count, wall_ms)
    return (f"{mode} @ presc={presc} bytes={byte_count} "
            f"sclk={_sclk_mhz(presc):.1f}MHz effective={mbps}Mbps "
            f"bench={ms}ms crc32={crc} expect={expect}{wall}")


def _bench_rates(match):
    byte_count = int(match.group(1))
    effective = float(match.group(5).decode("ascii"))
    wall = _wall_rate_mbps(byte_count, _bench_wall_ms())
    return effective, wall


def _mdma_rate_text(mode, presc, match):
    byte_count = int(match.group(1))
    ms = int(match.group(3))
    mbps = match.group(4).decode("ascii")
    crc = match.group(5).decode("ascii")
    expect = match.group(6).decode("ascii") if match.group(6) else "unknown"
    wall_ms = _bench_wall_ms()
    wall = _wall_text(byte_count, wall_ms)
    detail = ""
    if match.group(8) is not None:
        detail = (f" xfer={int(match.group(8))}ms"
                  f" validate={int(match.group(9))}ms"
                  f" poison={int(match.group(10))}ms")
    return (f"{mode} MDMA @ presc={presc} bytes={byte_count} "
            f"sclk={_sclk_mhz(presc):.1f}MHz effective={mbps}Mbps "
            f"bench={ms}ms crc32={crc} expect={expect}{detail}{wall}")


def _mdma_rates(match):
    byte_count = int(match.group(1))
    effective = float(match.group(4).decode("ascii"))
    wall = _wall_rate_mbps(byte_count, _bench_wall_ms())
    return effective, wall


def _stream_rate_text(mode, presc, match):
    byte_count = int(match.group(1))
    ms = int(match.group(3))
    mbps = match.group(4).decode("ascii")
    crc = match.group(5).decode("ascii")
    expect = match.group(6).decode("ascii")
    wall_ms = _bench_wall_ms()
    wall = _wall_text(byte_count, wall_ms)
    qspi = ""
    buf = match.group(10).decode() if match.group(10) else "unknown"
    auto = match.group(11).decode()
    if match.group(13) is not None:
        qspi = f" qspi_hz={int(match.group(13))}"
    return (f"{mode} stream @ presc={presc} bytes={byte_count} "
            f"sclk={_sclk_mhz(presc):.1f}MHz effective={mbps}Mbps "
            f"bench={ms}ms crc32={crc} expect={expect} "
            f"chunk={int(match.group(8))} "
            f"chunks={int(match.group(9))} buf={buf} auto={auto}"
            f"{qspi}{wall}")


def _stream_rates(match):
    byte_count = int(match.group(1))
    effective = float(match.group(4).decode("ascii"))
    wall = _wall_rate_mbps(byte_count, _bench_wall_ms())
    return effective, wall


def _stream_detail_block(mode, presc, match, wall):
    wall_text = "unknown" if wall is None else f"{wall:.3f}Mbps"
    buf = match.group(10).decode() if match.group(10) else "unknown"
    auto = match.group(11).decode()
    qspi = "unknown" if match.group(13) is None else match.group(13).decode()
    return (
        f"stream details:\n"
        f"  mode={mode} presc={presc} sclk={_sclk_mhz(presc):.3f}MHz "
        f"qspi_hz={qspi}\n"
        f"  effective={float(match.group(4).decode('ascii')):.3f}Mbps "
        f"wall_rate={wall_text} bench={int(match.group(3))}ms\n"
        f"  crc32={match.group(5).decode('ascii')} "
        f"expect={match.group(6).decode('ascii')} "
        f"firsterr={int(match.group(7))}\n"
        f"  chunk={int(match.group(8))} chunks={int(match.group(9))} "
        f"buf={buf} auto={auto}\n")


def _check_rates(rate, mode, presc, effective, wall):
    if not _check_rate_bounds("effective", mode, presc, effective):
        sys.stderr.write(rate + "\n")
        return False
    if wall is None:
        sys.stderr.write(f"wall_rate=unknown for {mode} presc={presc}\n")
        sys.stderr.write(rate + "\n")
        return False
    if not _check_rate_bounds("wall_rate", mode, presc, wall):
        sys.stderr.write(rate + "\n")
        return False
    return True


def _check_rates_with_clock(rate, mode, presc, effective, wall, qspi_hz,
                            byte_count=None, print_rate=True,
                            wall_floor_mbps=None):
    if not _check_physical_ceiling("effective", mode, presc, effective,
                                   qspi_hz):
        if print_rate:
            sys.stderr.write(rate + "\n")
        return False
    if not _check_physical_floor("effective", mode, presc, effective,
                                 qspi_hz, STREAM_EFFECTIVE_RATE_FLOOR):
        if print_rate:
            sys.stderr.write(rate + "\n")
        return False
    if wall is None:
        sys.stderr.write(f"wall_rate=unknown for {mode} presc={presc}\n")
        if print_rate:
            sys.stderr.write(rate + "\n")
        return False
    if not _check_physical_ceiling("wall_rate", mode, presc, wall, qspi_hz):
        if print_rate:
            sys.stderr.write(rate + "\n")
        return False
    if wall_floor_mbps is None:
        if not _check_physical_floor("wall_rate", mode, presc, wall,
                                     qspi_hz, STREAM_WALL_RATE_FLOOR):
            if print_rate:
                sys.stderr.write(rate + "\n")
            return False
    elif wall < wall_floor_mbps:
        sys.stderr.write(
            f"wall_rate={wall:.3f}Mbps below sanity floor "
            f"{wall_floor_mbps:.3f}Mbps for {mode} presc={presc}\n")
        if print_rate:
            sys.stderr.write(rate + "\n")
        return False
    return True


def _expected_crc32(byte_count):
    pattern = bytes(range(256)) * 16
    whole, rem = divmod(byte_count, len(pattern))
    crc = 0
    for _ in range(whole):
        crc = zlib.crc32(pattern, crc)
    if rem:
        crc = zlib.crc32(pattern[:rem], crc)
    return crc & 0xffffffff


def _check_crc(label, byte_count, got_hex):
    got = int(got_hex, 16)
    exp = _expected_crc32(byte_count)
    if got != exp:
        sys.stderr.write(
            f"{label} crc32={got:08x} expected={exp:08x}\n")
        return False
    return True


def check_pattern(mode, presc):
    if not v.check_no_errors():
        return False
    m = _bench_pick(mode, presc)
    if m is None:
        sys.stderr.write(
            f"no {mode} bench line for presc={presc}\n")
        raw = _read_uart()
        if raw:
            sys.stderr.write("--- last 512 bytes of UART ---\n")
            sys.stderr.write(raw[-512:].decode("ascii", "replace"))
            sys.stderr.write("\n")
        return False
    byte_count = int(m.group(1))
    fe = int(m.group(8))
    rate = _bench_rate_text(mode, presc, m)
    if not _check_crc(f"{mode} presc={presc}", byte_count,
                      m.group(6).decode("ascii")):
        sys.stderr.write(rate + "\n")
        return False
    if m.group(7) is not None:
        got = int(m.group(6), 16)
        exp = int(m.group(7), 16)
        if got != exp:
            sys.stderr.write(
                f"{mode} presc={presc} crc32={got:08x} expect={exp:08x}\n")
            sys.stderr.write(rate + "\n")
            return False
    if fe != -1:
        msg = f"{rate}: firsterr={fe} (expected -1)"
        tail = m.string[m.end():m.end() + 256]
        gm = re.search(rb"got=([0-9a-fA-F ]+?)(?=\r?\n|$)", tail)
        if gm:
            msg += f" got={gm.group(1).decode('ascii').strip()}"
        sys.stderr.write(msg + "\n")
        return False
    sys.stdout.write(rate + "\n")
    return True


def check_mdma_pattern(mode, presc):
    if not v.check_no_errors():
        return False
    m = _mdma_pick(mode)
    if m is None:
        sys.stderr.write(f"no {mode} mdma line\n")
        raw = _read_uart()
        if raw:
            sys.stderr.write("--- last 512 bytes of UART ---\n")
            sys.stderr.write(raw[-512:].decode("ascii", "replace"))
            sys.stderr.write("\n")
        return False
    byte_count = int(m.group(1))
    fe = int(m.group(7))
    rate = _mdma_rate_text(mode, presc, m)
    effective, wall = _mdma_rates(m)
    if not _check_rates(rate, mode, presc, effective, wall):
        return False
    if not _check_crc(f"{mode} MDMA presc={presc}", byte_count,
                      m.group(5).decode("ascii")):
        sys.stderr.write(rate + "\n")
        return False
    if m.group(6) is not None:
        got = int(m.group(5), 16)
        exp = int(m.group(6), 16)
        if got != exp:
            sys.stderr.write(
                f"{mode} MDMA presc={presc} crc32={got:08x} expect={exp:08x}\n")
            sys.stderr.write(rate + "\n")
            return False
    if fe != -1:
        sys.stderr.write(f"{rate}: firsterr={fe} (expected -1)\n")
        return False
    sys.stdout.write(rate + "\n")
    return True


def check_mdma_wall_rate_at_least(mode, presc, min_mbps):
    if not v.check_no_errors():
        return False
    m = _mdma_pick(mode, 1000000)
    if m is None:
        sys.stderr.write(f"no {mode} mdma line\n")
        raw = _read_uart()
        if raw:
            sys.stderr.write("--- last 512 bytes of UART ---\n")
            sys.stderr.write(raw[-512:].decode("ascii", "replace"))
            sys.stderr.write("\n")
        return False
    byte_count = int(m.group(1))
    fe = int(m.group(7))
    rate = _mdma_rate_text(mode, presc, m)
    _effective, wall = _mdma_rates(m)
    if not _check_crc(f"{mode} MDMA presc={presc}", byte_count,
                      m.group(5).decode("ascii")):
        sys.stderr.write(rate + "\n")
        return False
    if m.group(6) is not None:
        got = int(m.group(5), 16)
        exp = int(m.group(6), 16)
        if got != exp:
            sys.stderr.write(
                f"{mode} MDMA presc={presc} crc32={got:08x} expect={exp:08x}\n")
            sys.stderr.write(rate + "\n")
            return False
    if fe != -1:
        sys.stderr.write(f"{rate}: firsterr={fe} (expected -1)\n")
        return False
    if wall is None:
        sys.stderr.write(
            f"{rate}: wall_rate=unknown "
            f"(expected >= {min_mbps:.3f}Mbps)\n")
        return False
    if wall < min_mbps:
        sys.stderr.write(
            f"{rate}: wall_rate={wall:.3f}Mbps below {min_mbps:.3f}Mbps\n")
        return False
    sys.stdout.write(rate + f" wall_rate_floor={min_mbps:.3f}Mbps\n")
    return True


def _check_stream_shape(rate, match, expected_chunk=None, min_chunks=None):
    chunk = int(match.group(8))
    chunks = int(match.group(9))
    if expected_chunk is not None and chunk != expected_chunk:
        sys.stderr.write(
            f"{rate}: chunk={chunk} expected {expected_chunk}\n")
        return False
    if min_chunks is not None and chunks < min_chunks:
        sys.stderr.write(
            f"{rate}: chunks={chunks} below minimum {min_chunks}\n")
        return False
    return True


def check_stream_pattern(mode, presc, byte_count=1048576, max_wall_ms=None,
                         expected_chunk=None, min_chunks=None,
                         wall_floor_mbps=None):
    if not v.check_no_errors():
        return False
    m = _stream_pick(mode, byte_count, presc)
    if m is None:
        sys.stderr.write(f"no {mode} stream line for {byte_count} bytes\n")
        raw = _read_uart()
        if raw:
            sys.stderr.write("--- last 512 bytes of UART ---\n")
            sys.stderr.write(raw[-512:].decode("ascii", "replace"))
            sys.stderr.write("\n")
        return False
    byte_count = int(m.group(1))
    fe = int(m.group(7))
    rate = _stream_rate_text(mode, presc, m)
    effective, wall = _stream_rates(m)
    qspi_hz = int(m.group(13)) if m.group(13) is not None else QSPI_KER_HZ
    if not _check_rates_with_clock(rate, mode, presc, effective, wall,
                                   qspi_hz, byte_count,
                                   print_rate=False,
                                   wall_floor_mbps=wall_floor_mbps):
        sys.stderr.write(_stream_detail_block(mode, presc, m, wall))
        return False
    if not _check_crc(f"{mode} stream presc={presc}", byte_count,
                      m.group(5).decode("ascii")):
        sys.stderr.write(rate + "\n")
        return False
    got = int(m.group(5), 16)
    exp = int(m.group(6), 16)
    if got != exp:
        sys.stderr.write(
            f"{mode} stream crc32={got:08x} expect={exp:08x}\n")
        sys.stderr.write(rate + "\n")
        return False
    if fe != -1:
        sys.stderr.write(f"{rate}: firsterr={fe} (expected -1)\n")
        return False
    if m.group(11) != b"on":
        sys.stderr.write(f"{rate}: auto-consume is not on\n")
        return False
    if not _check_stream_shape(rate, m, expected_chunk, min_chunks):
        return False
    if max_wall_ms is not None:
        wall_ms = _bench_wall_ms()
        if wall_ms is None:
            sys.stderr.write(f"{rate}: wall time unknown\n")
            return False
        if wall_ms > max_wall_ms:
            sys.stderr.write(
                f"{rate}: wall={wall_ms:.0f}ms exceeds "
                f"{max_wall_ms}ms hard limit\n")
            return False
    sys.stdout.write(rate + "\n")
    return True


def check_stream_wall_rate_at_least(mode, presc, min_mbps, byte_count=1000000,
                                    max_wall_ms=None, expected_chunk=None,
                                    min_chunks=None):
    if not check_stream_pattern(mode, presc, byte_count, max_wall_ms,
                                expected_chunk, min_chunks):
        return False
    m = _stream_pick(mode, byte_count, presc)
    rate = _stream_rate_text(mode, presc, m)
    _effective, wall = _stream_rates(m)
    if wall is None:
        sys.stderr.write(
            f"{rate}: wall_rate=unknown "
            f"(expected >= {min_mbps:.3f}Mbps)\n")
        return False
    if wall < min_mbps:
        sys.stderr.write(
            f"{rate}: wall_rate={wall:.3f}Mbps below {min_mbps:.3f}Mbps\n")
        return False
    sys.stdout.write(rate + f" wall_rate_floor={min_mbps:.3f}Mbps\n")
    return True


def check_xor128_timing():
    if not v.check_no_errors():
        return False
    raw = _read_uart()
    if raw is None:
        return False
    m = XOR128_RE.search(raw)
    if m is None:
        sys.stderr.write("no xor128 timing line\n")
        sys.stderr.write(raw[-512:].decode("ascii", "replace") + "\n")
        return False
    length = int(m.group(1))
    iters = int(m.group(2))
    cached_ms = int(m.group(4))
    cached_us_x1000 = int(m.group(5))
    cold_ms = int(m.group(6))
    cold_us_x1000 = int(m.group(7))
    sys.stdout.write(
        f"xor128 len={length} iters={iters} "
        f"cached={cached_ms}ms ({cached_us_x1000 / 1000.0:.3f}us/half) "
        f"cold={cold_ms}ms ({cold_us_x1000 / 1000.0:.3f}us/half)\n")
    return length == 131072


def _make_dispatch():
    """Generate one DISPATCH entry per (mode, presc) pair declared in
    the hardware test plan. Keys exactly match the TEST.md bullets."""
    presc_steps = [203, 63, 15, 5]
    out = {}
    out["Measure MP135 128 KiB XOR timing"] = check_xor128_timing
    out["Check SPI header wiring via GPIO preflight"] = check_gpio_wiring
    out["Check 1lane bit-bang read returns incrementing pattern"] = (
        lambda: check_bitbang_pattern("1lane"))
    out["Check 1lane peripheral raw read returns 1024-byte incrementing pattern"] = (
        lambda: check_raw_read_pattern("1lane", 1024))
    out["Check 1lane peripheral raw read at presc=5 returns 512-byte incrementing pattern"] = (
        lambda: check_raw_read_pattern("1lane", 512))
    out["Check 1lane single-buffer DDR MDMA @ presc=203 pattern correct"] = (
        lambda: check_mdma_pattern("1lane", 203))
    for p in [63, 15, 5]:
        key = f"Check 1lane single-buffer DDR MDMA @ presc={p} pattern correct"
        out[key] = (lambda pr=p: check_mdma_pattern("1lane", pr))
    out["Check 1lane single-buffer DDR MDMA @ presc=5 wall rate >= 100 Mbps"] = (
        lambda: check_mdma_wall_rate_at_least("1lane", 5, 100.0))
    out["Check 1lane stream @ presc=203 pattern correct"] = (
        lambda: check_stream_pattern("1lane", 203, 1000000))
    out["Check 1lane stream @ presc=255 pattern correct"] = (
        lambda: check_stream_pattern("1lane", 255))
    out["Check 1lane stream @ presc=63 pattern correct"] = (
        lambda: check_stream_pattern("1lane", 63, 2097152))
    out["Check 1lane stream @ presc=15 pattern correct"] = (
        lambda: check_stream_pattern("1lane", 15, 1500000,
                                     wall_floor_mbps=32.0))
    out["Check 1lane stream @ presc=5 pattern correct"] = (
        lambda: check_stream_pattern("1lane", 5, 16842752,
                                     expected_chunk=16777216,
                                     min_chunks=2))
    out["Check 1lane stream @ presc=5 wall rate >= 100 Mbps"] = (
        lambda: check_stream_wall_rate_at_least("1lane", 5, 100.0, 33554432,
                                                expected_chunk=16777216,
                                                min_chunks=2))
    out["Check 1lane stream @ presc=5 512 MB stream_xfer wall rate >= 100 Mbps within 45 s, then pattern correct"] = (
        lambda: check_stream_wall_rate_at_least("1lane", 5, 100.0,
                                                512000000, 45000,
                                                expected_chunk=16777216,
                                                min_chunks=31))
    out["Check quad peripheral 0x6C one-hot diagnostic returns 12 48 pattern"] = (
        lambda: check_quad_onehot_read(32))
    out["Check quad peripheral 0x6E nibble-hold diagnostic returns 00 11 22 33 44 55 66 77 88 99 aa bb cc dd ee ff pattern"] = (
        lambda: check_quad_nibble_hold_read(32))
    out["Check quad peripheral 0x6F nibble-ramp diagnostic returns 01 23 45 67 89 ab cd ef pattern"] = (
        lambda: check_quad_nibble_ramp_read(32))
    out["Check quad peripheral read returns 1024-byte incrementing pattern"] = (
        lambda: check_raw_read_pattern("quad", 1024))
    out["Check FPGA UART debug reports first 32 SCLK edges"] = (
        check_debug_edges)
    out["Check FPGA UART debug first 32 IO1 samples are 00 01 02 03"] = (
        check_debug_samples)
    for mode in ("1lane", "quad"):
        for p in presc_steps:
            key = f"Check {mode} @ presc={p} pattern correct"
            out[key] = (lambda m=mode, pr=p: check_pattern(m, pr))
    out["Check quad peripheral 0x6D byte diagnostic returns 06 07 08 09 0a 0b 0c 0d pattern"] = (
        lambda: check_quad_byte_diag_read(32))
    out["Check quad bit-bang 6b command drives expected held pad nibbles"] = (
        check_quad_bitbang_pad_drive)
    return out


DISPATCH = _make_dispatch()


if __name__ == "__main__":
    sys.exit(v.main(DISPATCH, sys.argv))
@

=== Test runner

`build/spi/Makefile` is the entry point invoked from `cd build/spi
&& make test`. It re-tangles the plan and the verifier from
`src/spi.nw` so an edit to this chapter is picked up on the next
test run, then hands off to the shared `run_md.py` driver pointed at
by `$TEST_SERV`. The tangle recipes mirror the per-chapter rules in
the top Makefile but are reachable from inside the build directory
without invoking the parent.

<<Makefile>>=
NW := ../../src/spi.nw
MP135_QSPI_DIR := /home/claude/stm32mp135_test_board/baremetal/qspi/build
MP135_QSPI_SRC := /home/claude/stm32mp135_test_board/baremetal/qspi

.PHONY: all test bitstreams sim bitstream
all: TEST.md verify.py flash.tsv main.stm32

Makefile: $(NW)
	tangle Makefile < $<

test: all bitstreams
	python3 -u $$TEST_SERV/run_md.py --fresh --ledger ledger.txt --module spi --log run_md.log

bitstreams:
	$(MAKE) -C ../.. build/spi/pin_preflight build/spi/spi_1lane.bin build/spi/spi_quad.bin build/spi/qspi.bin

bitstream: bitstreams

sim:
	$(MAKE) -C ../.. build/spi/sim_1lane build/spi/sim_quad build/spi/netlist_check

TEST.md: $(NW)
	tangle TEST.md < $<

verify.py: $(NW)
	tangle verify.py < $<

flash.tsv:
	ln -sf $(MP135_QSPI_SRC)/flash.tsv $@

main.stm32:
	ln -sf $(MP135_QSPI_DIR)/main.stm32 $@
@
